#![no_main]

int write(int fd, const void *buf, unsigned int len);
int getpid(void);

static void puts(const char *s, unsigned int len) {
  write(1, s, len);
}

static void digit(int n) {
  if (n == 0)
    puts("0", 1);
  else if (n == 1)
    puts("1", 1);
  else if (n == 2)
    puts("2", 1);
  else if (n == 3)
    puts("3", 1);
  else
    puts("?", 1);
}

int main(void) {
  int pid = getpid();
  puts("hello: start pid=", 17);
  digit(pid);
  puts("\nhello: done\n", 13);
  return 0;
}
